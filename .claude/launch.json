{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "front-end", "run", "dev"],
      "port": 8080,
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": ".\\gradlew.bat",
      "runtimeArgs": ["bootRun", "--args=--spring.profiles.active=local"],
      "cwd": "back-end",
      "port": 8081,
      "autoPort": false
    }
  ]
}
