# Backend origin — no trailing slash.
# Leave unset in local dev (falls back to http://localhost:8081).
# Set to your production API domain in CI / hosting dashboard.
VITE_API_BASE_URL=https://api.kuky.es

# Public site URL used for SEO canonical tags.
# Leave unset in local dev (falls back to https://kuky.es).
VITE_SITE_URL=https://kuky.es
