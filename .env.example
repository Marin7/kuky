# Used by docker-compose.yml on the VM. Copy to .env and fill in real values.

# Postgres / back-end
DB_PASSWORD=change-me
APP_JWT_SECRET=change-me-hs256-key-at-least-32-chars
CORS_ALLOWED_ORIGIN=https://kuky.es
FRONTEND_BASE_URL=https://kuky.es
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENABLED=true
MAIL_FROM=noreply@kuky.es
TEACHER_EMAIL=paula@kuky.es
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_USER_ID=me

# Front-end (baked into the client bundle at build time)
VITE_API_BASE_URL=https://api.kuky.es
VITE_SITE_URL=https://kuky.es
