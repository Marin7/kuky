# -----------------------------------------------------------------------
# Kuky backend — required environment variables
# Copy this file, fill in real values, and set them in your deployment
# environment (hosting dashboard, secrets manager, etc.).
# Never commit real values to source control.
# -----------------------------------------------------------------------

# --- Database (PostgreSQL 18) ---
DB_URL=jdbc:postgresql://localhost:5432/kuky
DB_USERNAME=kuky
DB_PASSWORD=change-me

# --- JWT signing key ---
# Must be at least 32 characters. Generate with:
#   openssl rand -base64 48
APP_JWT_SECRET=change-me-at-least-32-characters-long

# --- CORS & frontend ---
# Set to your production frontend origin (no trailing slash).
CORS_ALLOWED_ORIGIN=https://kuky.es
# Used in password-reset and activation email links.
FRONTEND_BASE_URL=https://kuky.es

# --- Email (SMTP) ---
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@kuky.es
# MAIL_SMTP_AUTH and MAIL_SMTP_STARTTLS default to true — only set them if your
# provider requires something different (e.g. port 465 SSL uses starttls=false).
# Paula's address — receives booking/cancellation notifications.
TEACHER_EMAIL=paula@kuky.es

# --- Zoom (Server-to-Server OAuth) ---
# Leave all four blank to use the stub provider (returns zoom.invalid URLs).
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_USER_ID=me
